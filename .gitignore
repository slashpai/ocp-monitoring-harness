# Local task work — working documents, not committed (Jira/PR are the system of record)
/tasks/*
!/tasks/README.md
/completed/*
!/completed/.gitkeep

# Secrets and local cluster access — never commit
.env
.env.*
!.env.example
*.pem
*kubeconfig*

# OS files
.DS_Store
Thumbs.db

# Cursor — only .cursor/rules/ and .cursor/skills/ are committed
.cursor/*
!.cursor/rules/
!.cursor/rules/**
!.cursor/skills/
!.cursor/skills/**

/tmp/

# Editor files
*.swp
*.swo
*~
